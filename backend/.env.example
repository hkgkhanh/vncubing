# SQLAlchemy database connection URL
# Example: mysql+pymysql://user:password@localhost:3306/database_name
SQLALCHEMY_DATABASE_URL=

# JWT encryption/signing algorithm
# Example: HS256
ENCRYPT_ALGORITHM=

# Secret key used to sign JWT tokens and other sensitive data
SECRET_KEY=

# API version number
# Example: 1
API_VERSION=

# Allowed frontend origin for CORS
# Example: http://localhost:3000
ORIGIN=

# Backend base URL
# Example: http://localhost:8000
BACKEND_URL=

# Application environment
# Allowed values:
# - dev  : development mode
# - prod : production mode
ENV=

# WCA application client ID and secret
WCA_APP_ID=
WCA_SECRET=